# 소스 코드 및 텍스트 파일 (LFS 제외 대상)
*.cpp text diff=cpp
*.h text diff=cpp
*.cs text diff=csharp
*.ini text
*.txt text
*.json text
*.vcxproj text
*.xml text

# Unreal Engine Assets
